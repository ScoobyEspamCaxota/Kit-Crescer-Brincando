# ===== QuacPay (pagamento PIX) =====
# Pegue no painel QuacPay → Integrações API. NUNCA commitar o .env real.
QP_BASE=https://quacpay.com
QP_CLIENT_ID=qpc_production_xxxxxxxx
QP_CLIENT_SECRET=qps_xxxxxxxxx

# Segredo do webhook (validação da assinatura Quacpay-Signature)
QP_WEBHOOK_SECRET=

# Preço cobrado (definido pelo servidor, em reais)
PRICE=14.90
PRODUCT=Método Arraiá Lucrativo
# Downsell (oferta ao fechar o checkout) — deve ser MENOR que PRICE
DOWNSELL_PRICE=11.90
BUMP_PRICE=9.90
BUMP_PRODUCT=Saiba o preço certo e feche mais no WhatsApp
# 2o order bump (Pacote de Artes/Etiquetas) — crie o produto no Drive antes de subir
BUMP2_PRICE=12.90
BUMP2_PRODUCT=Artes prontas para etiquetas e divulgação

# ===== Utmify (rastreamento de vendas) =====
# Gere em Utmify -> Integrações -> Webhooks -> Credenciais de API.
UTMIFY_API_TOKEN=utmify_xxxxxxxxx
UTMIFY_ENDPOINT=https://api.utmify.com.br/api-credentials/orders
UTMIFY_PLATFORM=QuacPay
UTMIFY_IS_TEST=false

# Link entregue ao comprador depois que o pagamento for confirmado
DOWNLOAD_URL=https://drive.google.com/drive/folders/1KswTcAkTH30jCA5C7hPaqiMH6pGV1n8a?usp=drive_link
BUMP_DOWNLOAD_URL=https://drive.google.com/drive/folders/1mtZIZOccVIhbEhj0UEvua2sWfan3Y8Ev?usp=sharing
BUMP2_DOWNLOAD_URL=https://drive.google.com/drive/folders/1SozRku9jUNphHJxGTvSw00VM3meF3H_3?usp=sharing

# Porta do servidor
PORT=3000
