# ===== QuacPay (pagamento PIX) =====
# Pegue no painel QuacPay → Integrações API. NUNCA commitar o .env real.
QP_BASE=https://quacpay.com
QP_CLIENT_ID=qpc_production_xxxxxxxx
QP_CLIENT_SECRET=qps_xxxxxxxxx

# Segredo do webhook (validação da assinatura Quacpay-Signature)
QP_WEBHOOK_SECRET=

# Preço cobrado (definido pelo servidor, em reais)
PRICE=29.90
PRODUCT=Kit Crescer Brincando

# ===== Utmify (rastreamento de vendas) =====
# Gere em Utmify -> Integrações -> Webhooks -> Credenciais de API.
UTMIFY_API_TOKEN=utmify_xxxxxxxxx
UTMIFY_ENDPOINT=https://api.utmify.com.br/api-credentials/orders
UTMIFY_PLATFORM=QuacPay
UTMIFY_IS_TEST=false

# Porta do servidor
PORT=3000
